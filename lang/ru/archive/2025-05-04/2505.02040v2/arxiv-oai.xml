        <title>Tuning the Quantum Mpemba Effect in Isolated System by Initial State Engineering</title>
            <categories>quant-ph</categories>
            <comments>11 pages, 6 figures</comments>
            <journal-ref>Physical Review B, 2025, 112(9): 094315</journal-ref>
