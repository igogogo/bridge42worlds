        <title>Discrete time crystals enhanced by Stark potentials in Rydberg atom arrays</title>
            <categories>quant-ph cond-mat.dis-nn cond-mat.quant-gas</categories>
            <comments>5 pages, 5 figures</comments>
            <journal-ref>Physics Letters A 558 (2025) 130896</journal-ref>
