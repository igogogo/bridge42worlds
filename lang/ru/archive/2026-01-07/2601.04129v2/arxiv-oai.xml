        <title>Satellite-borne $Î³$-ray astrophysics from coherent interactions in oriented crystals</title>
            <categories>astro-ph.HE</categories>
            <journal-ref>A&amp;A 710, A255 (2026)</journal-ref>
            <doi>10.1051/0004-6361/202658973</doi>
